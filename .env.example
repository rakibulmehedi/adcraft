# ──────────────────────────────────────────────────────────────────────────────
# AdCraft — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Required: OpenAI API key
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: Change the LLM model (default: gpt-4o-mini)
# Other options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Optional: LLM temperature (0.0 = deterministic, 1.0 = creative)
OPENAI_TEMPERATURE=0.7

# Optional: Max tokens per LLM request
OPENAI_MAX_TOKENS=1024

# Optional: HuggingFace models (defaults shown below)
# Sentiment: cardiffnlp/twitter-roberta-base-sentiment-latest
# Safety:    unitary/toxic-bert
HF_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
HF_SAFETY_MODEL=unitary/toxic-bert

# Optional: HuggingFace device (-1 = CPU, 0 = first GPU)
HF_DEVICE=-1

# Optional: Debug mode (false in production)
DEBUG=false

# Optional: CORS allowed origins (default allows all — restrict in production)
# CORS_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]
